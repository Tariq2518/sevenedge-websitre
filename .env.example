# ---------------------------------------------------------------------------
# 7edge Apps — environment variables
# Copy this file to ".env.local" and fill in the values you need.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, robots, structured data,
# Open Graph and llms.txt). Set this to your final production domain.
NEXT_PUBLIC_SITE_URL=https://sevenedge.pages.dev

# ---------------------------------------------------------------------------
# Contact form (OPTIONAL — server-side email via Resend).
# If these are not set, the contact form automatically falls back to opening
# the visitor's email client (mailto). The site stays fully functional either
# way. See README.md → "Activating the contact form".
# ---------------------------------------------------------------------------
RESEND_API_KEY=
# The "from" address must be a domain you have verified in Resend.
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Where contact submissions are delivered.
CONTACT_TO_EMAIL=7edgetechnologies@gmail.com
